{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Key": "<set-in-local-appsettings>",
  "JwtSettings": {
    "Key": "<set-in-local-appsettings>",
    "Issuer": "IssuerApplyAI",
    "Audience": "IssuerApplyAI",
    "Actor": "ApplyAIApp",
    "DurationInMinutes": 15
  },
  "OpenAI": {
    "ApiKey": "<set-in-local-appsettings>"
  },
  "Verification": {
    "GateEnabled": true,
    "MaxRepairAttemptsPerStage": 1,
    "MaxRegenerationAttemptsPerStage": 1,
    "Stages": {
      "Requirements": {
        "BlockOnAnyHardInvalid": true,
        "MinRequirements": 1
      },
      "CandidateEvidence": {
        "BlockOnAnyHardInvalid": true,
        "MaxDiscardRatio": 0.4,
        "MinApprovedItems": 4,
        "MinCoveredRequirements": 3,
        "MinStrongOrMediumItems": 2
      },
      "Matching": {
        "BlockOnAnyHardInvalid": true,
        "MinRequirementCoverageRatio": 0.75,
        "AllowHighConfidenceWithoutEvidence": false,
        "AllowMatchesWithoutEvidence": false
      },
      "ApplicationGeneration": {
        "BlockOnAnyHardInvalid": true,
        "MaxUnsupportedClaims": 0,
        "MaxDanglingRelations": 0,
        "MaxUnsupportedSections": 0
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=15432;Database=BorgerserviceDb;Username=postgres;Password=Kode1234!"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "BackBlaze": {
    "KeyName": "<set-in-local-appsettings>",
    "Keyid": "<set-in-local-appsettings>",
    "Bucket": "<set-in-local-appsettings>",
    "ApplicationKey": "<set-in-local-appsettings>",
    "ServiceUrl": "https://s3.eu-central-003.backblazeb2.com",
    "DownloaderAuthenticationRegion": "eu-central-1",
    "DownloaderRegionSystemName": "eu-central-1",
    "ForcePathStyle": true,
    "UploaderAuthenticationRegion": "eu-central-003",
    "UploaderUseHttp": false
  }
}