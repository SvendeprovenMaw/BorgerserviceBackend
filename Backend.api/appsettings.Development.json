{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Key": "<set-in-local-appsettings>",
  "JwtSettings": {
    "Key": "<set-in-local-appsettings>",
    "Issuer": "IssuerInventoryBackend",
    "Audience": "IssuerInventoryBackend",
    "Actor": "TauriApp",
    "DurationInMinutes": 15
  },
  "OpenAi": {
    "SecretKey": "<set-in-local-appsettings>"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=15432;Database=BorgerserviceDb;Username=postgres;Password=<set-in-local-appsettings>"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "BackBlaze": {
    "KeyName": "<set-in-local-appsettings>",
    "Keyid": "<set-in-local-appsettings>",
    "Bucket": "<set-in-local-appsettings>",
    "ApplicationKey": "<set-in-local-appsettings>"
  }
}
