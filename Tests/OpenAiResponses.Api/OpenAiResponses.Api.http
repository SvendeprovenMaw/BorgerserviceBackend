@OpenAiResponses.Api_HostAddress = http://localhost:5026

# Quick smoke test for the helper endpoint that returns a valid strict-json payload.
GET {{OpenAiResponses.Api_HostAddress}}/api/responses/sample-request
Accept: application/json

###

# Generic strict-json call with explicit files and schema.
POST {{OpenAiResponses.Api_HostAddress}}/api/responses/strict-json
Content-Type: application/json

{
	"personFiles": [
		"../../TestData/Borgere/Borger1/emma_sorensen_cv_da.pdf",
		"../../TestData/Borgere/Borger1/profile.pdf"
	],
	"jobApplication": "../../TestData/Opslag/DevOps Udvikler - JN Data - Roskilde eller Silkeborg.pdf",
	"schemaName": "candidate_job_match",
	"schemaDescription": "Structured candidate match output",
	"outputSchema": {
		"type": "object",
		"properties": {
			"candidateName": { "type": "string" },
			"overallMatchScore": { "type": "number" },
			"summary": { "type": "string" },
			"strengths": {
				"type": "array",
				"items": { "type": "string" }
			},
			"concerns": {
				"type": "array",
				"items": { "type": "string" }
			}
		},
		"required": ["candidateName", "overallMatchScore", "summary", "strengths", "concerns"],
		"additionalProperties": false
	},
	"prompt": "Compare the person files to the job application and explain the candidate fit."
}

###

# Stage-by-stage requests for inspecting the sample pipeline incrementally.
POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/requirements

###

POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/candidate-evidence

###

POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/matching

###

POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/pipeline
Content-Type: application/json
Accept: application/json

{
	"candidateNumber": 1,
	"jobPostingNumber": 3
}

###

# Full pipeline requests used when testing verification, gates, and repair behavior.
POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/pipeline-with-verification
Content-Type: application/json
Accept: application/json

{
	"candidateNumber": 2,
	"jobPostingNumber": 5
}

# Inspect these fields in the response:
# - CandidateDirectory
# - JobListingFileName
# - PipelineStatus
# - StoppedAfterStage
# - CoverLetter.PdfArtifactPath
# - Verification.RecommendedAction
# - Verification.Stages[*].Gate.Decision
# - Verification.Stages[*].GateArtifactPath
# When a stage is blocked by its downstream gate, ApplicationDocument is null.

###

# Batch run across every sample job listing so output quality can be compared side by side.
POST {{OpenAiResponses.Api_HostAddress}}/api/responses/sample/pipeline-with-verification/all-jobs
Accept: application/json

# Returns one compact summary per job listing in TestData/Opslag.
# Useful fields:
# - Jobs[*].OverallMatchLevel
# - Jobs[*].MatchedCount / PartiallyMatchedCount / NotMatchedCount / UnclearCount
# - Jobs[*].ApplicationGenerated
# - Jobs[*].ApplicationCoreMessageDa

###
