{
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-5-mini",
    "PricingCurrency": "USD",
    "InputCostPerMillionTokens": null,
    "OutputCostPerMillionTokens": null
  },
  "Verification": {
    "GateEnabled": true,
    "MaxRepairAttemptsPerStage": 1,
    "MaxRegenerationAttemptsPerStage": 1,
    "Stages": {
      "Requirements": {
        "BlockOnAnyHardInvalid": true,
        "MinRequirements": 1
      },
      "CandidateEvidence": {
        "BlockOnAnyHardInvalid": true,
        "MaxDiscardRatio": 0.4,
        "MinApprovedItems": 4,
        "MinCoveredRequirements": 3,
        "MinStrongOrMediumItems": 2
      },
      "Matching": {
        "BlockOnAnyHardInvalid": true,
        "MinRequirementCoverageRatio": 0.75,
        "AllowHighConfidenceWithoutEvidence": false,
        "AllowMatchesWithoutEvidence": false
      },
      "ApplicationGeneration": {
        "BlockOnAnyHardInvalid": true,
        "MaxUnsupportedClaims": 0,
        "MaxDanglingRelations": 0,
        "MaxUnsupportedSections": 0
      }
    }
  },
  "SamplePipeline": {
    "CandidateRootPath": "TestData/Borgere",
    "DefaultCandidateDirectory": "Borger1",
    "PreferencesFileName": "Preferences.json",
    "JobListingsPath": "TestData/Opslag",
    "ParsingSchemasPath": "LLM/AI Schemas/LLM Parsing",
    "ResultsPath": "LLM/Results",
    "RunDirectoryPrefix": "Run ",
    "CoverLetterTemplate": {
      "TemplatesPath": "Tests/OpenAiResponses.Api/Templates",
      "HtmlTemplateFileName": "cover-letter-template.html",
      "CssTemplateFileName": "cover-letter-template.css",
      "OutputDirectoryName": "cover_letter",
      "RenderedHtmlFileName": "cover_letter.html",
      "RenderedCssFileName": "cover_letter.css",
      "RenderSummaryFileName": "cover_letter_render_summary.json",
      "MaxMainContentCharacters": 2200
    },
    "DefaultFitStrategy": {
      "GuidanceMode": "optimistic",
      "IncludeFitAdvisory": false,
      "AllowApplicationOnWeakMatch": true,
      "PreferTransferableStrengthsWhenDirectMatchIsWeak": true,
      "AllowStretchPositioning": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
