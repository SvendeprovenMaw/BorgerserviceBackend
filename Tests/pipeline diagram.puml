@startuml
!theme plain
title Sample Pipeline Activity Diagram

skinparam Shadowing false
skinparam ActivityBorderColor Black
skinparam ActivityBackgroundColor White
skinparam ArrowColor Black
skinparam BackgroundColor White

start

:POST /api/responses/sample/pipeline;

partition "Pipeline setup" {
  :Load sample data;
  note right
    Inputs discovered from sample data:
    - job application PDF
    - candidate documents
    - Preferences.json
  end note

  :Build document IDs;
  :Create run folder
  (LLM/Results/Run N);
}

partition "Phase 1 - Requirements parsing" {
  :Merge base.prompt
  with requirements.prompt;
  :Load requirements_schema.json;
  :Send job application PDF
  to OpenAI Responses API;
  :Receive requirements JSON;
  :Save requirements.json;
}

partition "Phase 2 - Candidate evidence" {
  :Merge base.prompt
  with candidate_evidence.prompt;
  :Load candidate_evidence_schema.json;
  :Prepare inputs:
  - requirements document ID + JSON
  - candidate documents
  - exclude Preferences.json;
  :Send candidate evidence request
  to OpenAI Responses API;
  :Receive candidate evidence JSON;
  :Save candidate_evidence.json;
}

partition "Phase 3 - Matching" {
  :Merge base.prompt
  with matching.prompt;
  :Load matching_schema.json;
  :Prepare inputs:
  - requirements document ID + JSON
  - candidate evidence document ID + JSON;
  :Send matching request
  to OpenAI Responses API;
  :Receive matching JSON;
  :Save matching.json;
}

partition "Phase 4 - Application generation" {
  :Merge base.prompt
  with application_generation.prompt;
  :Load application_generation_schema.json;
  :Prepare inputs:
  - application document ID
  - requirements document ID + JSON
  - candidate evidence document ID + JSON
  - matching document ID + JSON
  - Preferences.json;
  :Send application generation request
  to OpenAI Responses API;
  :Receive application generation JSON;
  :Save application_generation.json;
}

partition "Pipeline completion" {
  :Return application_generation.json
  as HTTP response body;
}

stop
@enduml